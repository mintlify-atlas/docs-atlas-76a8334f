  "keyFeatures": [
    "Automatic incident detection via Prometheus Alertmanager webhook",
    "LangGraph multi-agent pipeline: classification, investigation, decision, action, post-mortem",
    "Human-in-the-loop action approval before any remediation command is executed",
    "Specialist agents for Docker, Podman, Kubernetes, and PostgreSQL",
    "RAG-powered runbook retrieval using ChromaDB vector store",
    "Episodic memory for similar incident lookup across past incidents",
    "Deterministic guardrails for prompt injection defense and action whitelisting",
    "Automated post-mortem generation with LLM and MTTR calculation",
    "Real-time dashboard updates via Supabase Realtime subscriptions",
    "Agent observability via LangFuse tracing"
  ],
  "publicApiSurface": [
